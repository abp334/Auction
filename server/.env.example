# Database (PostgreSQL)
# For Supabase: use pooled URL (port 6543) as DATABASE_URL and direct URL (port 5432) as DIRECT_URL
DATABASE_URL=postgresql://bidarena:bidarena@localhost:5432/bidarena
DIRECT_URL=postgresql://bidarena:bidarena@localhost:5432/bidarena

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (use different values for access and refresh in production)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
# Fallback: JWT_SECRET is used if the above are not set
# JWT_SECRET=your-jwt-secret

# Server
PORT=5001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:8080

# EmailJS (for OTP emails)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_USER_ID=
EMAILJS_PRIVATE_KEY=

# Signup Gating — set a bypass code for testing (any signup using this code skips invite validation)
SIGNUP_BYPASS_CODE=TESTBYPASS

# Super Admin — only these emails can generate/manage invite codes (comma-separated)
SUPER_ADMIN_EMAILS=your-email@example.com

# Logging
LOG_LEVEL=info
