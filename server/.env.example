# Database (PostgreSQL)
DATABASE_URL=postgresql://bidarena:bidarena@localhost:5432/bidarena

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (use different values for access and refresh in production)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
# Fallback: JWT_SECRET is used if the above are not set
# JWT_SECRET=your-jwt-secret

# Server
PORT=5001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:8080

# EmailJS (for OTP emails)
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_USER_ID=
EMAILJS_PRIVATE_KEY=

# Logging
LOG_LEVEL=info
